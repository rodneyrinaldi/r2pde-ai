{
    "name": "r2pde-ai",
    "version": "0.1.1",
    "description": "Pilot Driven Engineering â€” A CLI framework that bridges the gap between architectural intent and AI-generated code.",
    "license": "MIT",
    "main": "dist/index.js",
    "bin": {
        "r2pde-ai": "dist/cli.js"
    },
    "type": "module",
    "scripts": {
        "lint": "echo \"Linting not configured\"",
        "build": "rimraf dist && tsc && npm run copy-templates && npm run copy-guide && npm run postbuild:cli",
        "copy-guide": "node -e \"require('fs').copyFileSync('scaffold-guide.yaml','dist/scaffold-guide.yaml')\"",
        "postbuild:cli": "node scripts/postbuild-cli.cjs",
        "copy-templates": "node -e \"const fs=require('fs');const path=require('path');const src=path.join('src','templates');const dest=path.join('dist','templates');fs.mkdirSync(dest,{recursive:true});fs.readdirSync(src).forEach(f=>fs.copyFileSync(path.join(src,f),path.join(dest,f)));\"",
        "dev": "ts-node src/cli.ts",
        "start": "node dist/cli.js",
        "test": "vitest run",
        "test:scaffold": "npm run build && node ./dist/cli.js scaffold-create --guide scaffold-guide.yaml",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@inquirer/prompts": "^8.4.3",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "fs-extra": "^11.3.5",
        "inquirer": "^13.4.3",
        "js-yaml": "^4.1.1",
        "ora": "^9.4.0"
    },
    "devDependencies": {
        "@types/fs-extra": "^11.0.4",
        "@types/inquirer": "^9.0.9",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25.8.0",
        "@vitest/coverage-v8": "^4.1.6",
        "rimraf": "^6.1.3",
        "ts-node": "^10.9.2",
        "tsx": "^4.22.0",
        "typescript": "^6.0.3",
        "vitest": "^4.1.6"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "CHANGELOG.md",
        "ONBOARDING-QUICKSTART.md",
        "scaffold-guide.yaml"
    ],
    "engines": {
        "node": ">=20.0.0"
    },
    "keywords": [
        "cli",
        "ai",
        "copilot",
        "engineering",
        "pde",
        "pilot-driven",
        "scaffold",
        "typescript"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/rodneyrinaldi/r2pde-ai.git"
    },
    "bugs": {
        "url": "https://github.com/rodneyrinaldi/r2pde-ai/issues"
    },
    "homepage": "https://r2pde-ai.rrs.net.br"
}
