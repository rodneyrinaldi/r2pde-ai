{
    "compilerOptions":  {
        "rootDir": ".",
                            "target":  "ESNext",
                            "module":  "NodeNext",
                            "moduleResolution":  "NodeNext",
                            "outDir":  "./dist",
                            "strict":  true,
                            "esModuleInterop":  true,
                            "skipLibCheck":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "types":  [
                                          "node"
                                      ]
                        },
    "include":  [
                    "src/**/*",
                    "scripts/**/*",
                    "scaffold_test/**/*"
                ],
    "exclude":  [
                    "node_modules",
                    "dist"
                ]
}
